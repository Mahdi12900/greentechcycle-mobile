{
  "expo": {
    "name": "GreenTechCycle Scanner",
    "slug": "greentechcycle-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.greentechcycle.scanner",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GreenTechCycle needs camera access to scan device barcodes and QR codes.",
        "NSPhotoLibraryUsageDescription": "GreenTechCycle needs photo library access to attach device photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.greentechcycle.scanner",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "GreenTechCycle needs camera access to scan device barcodes and QR codes."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "4c2b3f84-1992-43f1-83de-743e6698bd5e"
      }
    },
    "owner": "mahdibouaraba"
  }
}
